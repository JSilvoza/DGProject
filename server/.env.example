NODE_ENV=development
PORT=3000

# PostgreSQL — set to your local or hosted instance
DATABASE_URL=postgresql://postgres:password@localhost:5432/dg_studio

# Redis — set to your local or hosted instance
REDIS_URL=redis://localhost:6379

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# CORS — origin(s) allowed to call this API
CORS_ORIGIN=http://localhost:5500

# Cache TTLs (seconds)
TTL_PRODUCT_LIST=300
TTL_PRODUCT_SINGLE=300
TTL_CART=3600
